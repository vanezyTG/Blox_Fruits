-- Создание ESP для фрукта
local function CreateFruitESP(fruit)
    if not FARM_SETTINGS.EnableESP then return end
    if fruit:FindFirstChild("FruitESP") then return end
    if not fruit:FindFirstChild("Handle") then return end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "FruitESP"
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.AlwaysOnTop = true
    billboard.Parent = fruit.Handle

