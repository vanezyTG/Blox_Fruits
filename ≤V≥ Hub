        b.MouseLeave:Connect(function() tw(b, 0.14, { Size = UDim2.new(0, 100, 0, 38) }, Enum.EasingStyle.Back) end)
        return b
    end
    local saveBtn = actBtn("Save", rgb(50, 175, 80))
    local exitBtn = actBtn("Exit", rgb(200, 60, 60))

    local handles = {}
    local startW, startH, startMouse, activeHandle
    local sessionStartW, sessionStartH = 0, 0

    local function makeHandle(edge)
        local h = Instance.new("TextButton")
        h.Text = ""
        h.AutoButtonColor = false
        h.BackgroundColor3 = WHITE
        h.BackgroundTransparency = 0.25
        h.Visible = false
        h.ZIndex = 54
        h.Parent = win
        corner(h, 4)
        local hg = Instance.new("UIGradient"); hg.Color = rainbowSequence(); hg.Parent = h
        conn(RunService.RenderStepped:Connect(function()
            if h.Visible then hg.Rotation = (hg.Rotation + 1.5) % 360 end
        end))
        if edge == "left" then
            h.AnchorPoint = Vector2.new(0, 0.5); h.Position = UDim2.new(0, 3, 0.5, 0); h.Size = UDim2.new(0, 6, 0, 60)
        elseif edge == "right" then
            h.AnchorPoint = Vector2.new(1, 0.5); h.Position = UDim2.new(1, -3, 0.5, 0); h.Size = UDim2.new(0, 6, 0, 60)
        elseif edge == "top" then
            h.AnchorPoint = Vector2.new(0.5, 0); h.Position = UDim2.new(0.5, 0, 0, 3); h.Size = UDim2.new(0, 70, 0, 6)
        else
            h.AnchorPoint = Vector2.new(0.5, 1); h.Position = UDim2.new(0.5, 0, 1, -3); h.Size = UDim2.new(0, 70, 0, 6)
        end
        h.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                activeHandle = edge
                startW, startH = W, H
                startMouse = UserInputService:GetMouseLocation()
                tw(h, 0.12, { BackgroundTransparency = 0 })
            end
        end)
        h.MouseEnter:Connect(function() tw(h, 0.12, { BackgroundTransparency = 0.05 }) end)
        h.MouseLeave:Connect(function() if activeHandle ~= edge then tw(h, 0.15, { BackgroundTransparency = 0.25 }) end end)
        handles[edge] = h
    end
    makeHandle("left"); makeHandle("right"); makeHandle("top"); makeHandle("bottom")

    conn(UserInputService.InputChanged:Connect(function(i)
        if activeHandle and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
            local d = UserInputService:GetMouseLocation() - startMouse
            if activeHandle == "right" then applyWindowSize(startW + d.X * 2, H)
            elseif activeHandle == "left" then applyWindowSize(startW - d.X * 2, H)
            elseif activeHandle == "bottom" then applyWindowSize(W, startH + d.Y * 2)
            elseif activeHandle == "top" then applyWindowSize(W, startH - d.Y * 2) end
        end
    end))
    conn(UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            if activeHandle and handles[activeHandle] then
                tw(handles[activeHandle], 0.15, { BackgroundTransparency = 0.25 })
            end
            activeHandle = nil
        end
    end))

    local function setResizeVisual(on)
        dim.Visible = true
        actions.Visible = true
        for _, h in pairs(handles) do h.Visible = true end
        if on then
            tw(dim, 0.25, { BackgroundTransparency = 0.5 })
        end
    end

    local function finishResize()
        resizeActive = false
        tw(dim, 0.25, { BackgroundTransparency = 1 })
        for _, h in pairs(handles) do tw(h, 0.2, { BackgroundTransparency = 1 }) end
        task.delay(0.26, function()
            if not resizeActive then
                dim.Visible = false
                actions.Visible = false
                for _, h in pairs(handles) do h.Visible = false; h.BackgroundTransparency = 0.25 end
            end
        end)
    end

    enterResize = function()
        if resizeActive then return end
        resizeActive = true
        sessionStartW, sessionStartH = W, H
        actions.Visible = true
        exitBtn.Visible = true
        setResizeVisual(true)
        notify("Resize mode", "Drag edge handles to resize, then Save or Exit.", 6)
    end

    saveBtn.MouseButton1Click:Connect(function()
        saveConfig()
        finishResize()
        notify("Size saved", "Window size has been saved.", 3)
    end)

    exitBtn.MouseButton1Click:Connect(function()
        if W == sessionStartW and H == sessionStartH then
            finishResize()
            return
        end
        actions.Visible = false
        showConfirm("Exit without saving?", "Keep the new size or revert?",
            function()
                saveConfig()
                finishResize()
                notify("Size saved", "New window size kept.", 3)
            end,
            {
                yesText = "✓", noText = "×", noDismiss = true,
                onNo = function()
                    applyWindowSize(sessionStartW, sessionStartH, true)
                    finishResize()
                end,
            })
    end)
end

