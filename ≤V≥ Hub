-- Удаление ESP
local function RemoveFruitESP(fruit)
    if farmESPObjects[fruit] then
        farmESPObjects[fruit]:Destroy()
        farmESPObjects[fruit] = nil
    end
    local esp = fruit:FindFirstChild("FruitESP")
    if esp then esp:Destroy() end
end

-- Очистка всех ESP
local function ClearAllFruitESP()
    for fruit, esp in pairs(farmESPObjects) do
        pcall(function() esp:Destroy() end)
    end
    farmESPObjects = {}
end

-- Твин к позиции
local function TweenTo(position)
    local char = LP.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local distance = (hrp.Position - position).Magnitude
    local time = math.min(distance / FARM_SETTINGS.TweenSpeed, 10)
    
    local tween = TweenService:Create(
        hrp,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {CFrame = CFrame.new(position)}
    )
    tween:Play()
    tween.Completed:Wait()
end

-- Хранение фрукта
local function StoreFruit(fruit)
    local remote = getCommF()
    if not remote then return end
    
    local success, err = pcall(function()
        remote:InvokeServer(
            "StoreFruit",
            fruit:GetAttribute("OriginalName") or fruit.Name,
            fruit
        )
    end)
    
    if not success then
        warn("Failed to store fruit: " .. tostring(err))
    end
end

-- Основной цикл фарма
local function FarmCycle()
    local char = LP.Character
    if not char then return end
    
    -- Получаем все фрукты
    local fruits = GetAllFruits()
    
    if #fruits == 0 then
        -- Нет фруктов - хопим
        task.wait(2)
        ServerHop()
        return
    end
    
    -- Создаём ESP для всех фруктов
    for _, fruit in pairs(fruits) do
        CreateFruitESP(fruit)
    end
    
    -- Находим лучший фрукт
    local target = GetBestFruit(fruits)
    
    if not target then
        -- Нет разрешённых фруктов - хопим
        task.wait(2)
        ServerHop()
        return
    end
    
    -- Телепортируемся к фрукту
    local handle = target:FindFirstChild("Handle")
    if not handle then return end
    
    TweenTo(handle.Position)
    task.wait(1)
    
    -- Забираем фрукт
    StoreFruit(target)
    task.wait(2)
    
    -- Хопим на новый сервер
    ServerHop()
end

-- Запуск фарма
local function StartFarm()
    if farmRunning then return end
    farmRunning = true
    
    -- Устанавливаем команду
    setTeam()
    
    -- Запускаем цикл
    farmConnection = RunService.RenderStepped:Connect(function()
        if not cfg.auto_farm_fruits then
            StopFarm()
            return
        end
        
        local char = LP.Character
        if not char then return end
        
        -- Запускаем цикл фарма в отдельном потоке
        task.spawn(function()
            if farmRunning and cfg.auto_farm_fruits then
                FarmCycle()
            end
        end)
    end)
    
    notify("Auto Farm", "Started farming fruits!", 3)
end

-- Остановка фарма
local function StopFarm()
    farmRunning = false
    if farmConnection then
        farmConnection:Disconnect()
        farmConnection = nil
    end
    ClearAllFruitESP()
    notify("Auto Farm", "Stopped farming fruits.", 3)
end

