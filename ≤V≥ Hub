--  THEME  (preferred color drives the whole GUI)
--==================================================================--
local PRESETS = {
    red   = { name = "red",   c = rgb(235, 60, 60) },
    blue  = { name = "blue",  c = rgb(60, 130, 255) },
    green = { name = "green", c = rgb(60, 210, 110) },
}

local theme = {
    key     = "red",
    primary = PRESETS.red.c,
    dark    = rgb(16, 16, 20),
    header  = rgb(10, 10, 14),
}

local themeUpdaters = {}
local function onTheme(fn) themeUpdaters[#themeUpdaters + 1] = fn; fn(theme.primary) end
local function applyTheme() for _, fn in ipairs(themeUpdaters) do safe(fn, theme.primary) end end

local function saveConfig()
    ensureFolder()
    local data = { color = theme.key }
    for k, v in pairs(cfg) do data[k] = v end
    safe(function() _writefile(CFG_PATH, HttpService:JSONEncode(data)) end)
end

local function loadConfig()
    if not _isfile(CFG_PATH) then return end
    local ok, data = pcall(function() return HttpService:JSONDecode(_readfile(CFG_PATH)) end)
    if not ok or type(data) ~= "table" then return end
    if data.color and PRESETS[data.color] then
        theme.key = data.color
        theme.primary = PRESETS[data.color].c
    end
    for k, v in pairs(data) do if cfg[k] ~= nil then cfg[k] = v end end
end
loadConfig()

