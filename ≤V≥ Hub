local MIN_W, MAX_W = 300, 9999
local MIN_H, MAX_H = 200, 9999

applyWindowSize = function(w, h, animate)
    W = math.clamp(math.floor(w), MIN_W, MAX_W)
    H = math.clamp(math.floor(h), MIN_H, MAX_H)
    cfg.win_w, cfg.win_h = W, H
    if windowShown then
        if animate then tw(win, 0.25, { Size = UDim2.new(0, W, 0, H) })
        else win.Size = UDim2.new(0, W, 0, H) end
    end
end

do
    local dim = Instance.new("TextButton")
